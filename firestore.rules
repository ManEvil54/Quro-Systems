rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---- HELPER FUNCTIONS ----
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user is a Master Admin (Uses system-level claim or global user record)
    function isMasterAdmin() {
      return isAuthenticated() && (
        ('role' in request.auth.token && (
          request.auth.token.role == 'SUPER_ADMIN' || 
          request.auth.token.role == 'APP_OWNER' || 
          request.auth.token.role == 'APP_TECH'
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'APP_OWNER' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'APP_TECH'
          )
        ))
      );
    }

    // Custom Claims scope with robust local/dev fallbacks
    function isOrgMember(orgId) {
      return isAuthenticated() && (
        ('orgId' in request.auth.token && request.auth.token.orgId == orgId) || 
        isMasterAdmin() || 
        isOrgPrimaryContact(orgId) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'org_id' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.org_id == orgId) ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid))
      );
    }

    function isOrgPrimaryContact(orgId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/organizations/$(orgId)) && 
             'contact_email' in get(/databases/$(database)/documents/organizations/$(orgId)).data &&
             'email' in request.auth.token &&
             get(/databases/$(database)/documents/organizations/$(orgId)).data.contact_email == request.auth.token.email;
    }

    function hasRole(roles) {
      return isAuthenticated() && (
        ('role' in request.auth.token && request.auth.token.role in roles) ||
        isMasterAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         'role' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles)
      );
    }

    function hasOrgRole(orgId, roles) {
      return hasRole(roles) ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)) && 
         'role' in get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data &&
         get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.role in roles);
    }

    function hasFacilityAccess(orgId, facilityId) {
      return isMasterAdmin() || 
             (isAuthenticated() && (
                ('facilityIds' in request.auth.token && request.auth.token.facilityIds != null && facilityId in request.auth.token.facilityIds) || 
                ('role' in request.auth.token && request.auth.token.role in ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']) ||
                isOrgPrimaryContact(orgId) ||
                (exists(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)) && (
                   ('facility_id' in get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data &&
                    get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.facility_id == facilityId) ||
                   ('assigned_facility_ids' in get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data &&
                    get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.assigned_facility_ids != null &&
                    facilityId in get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.assigned_facility_ids) ||
                   ('role' in get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data &&
                    get(/databases/$(database)/documents/organizations/$(orgId)/staff/$(request.auth.uid)).data.role in ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN'])
                ))
             ));
    }

    // DATA VALIDATION: Defensive check against malformed/malicious clinical data
    function isValidVital(data) {
      return data.pulse is number && data.pulse >= 0 && data.pulse <= 300 &&
             data.spO2 is number && data.spO2 >= 0 && data.spO2 <= 100 &&
             data.recorded_at is timestamp &&
             data.recorded_by == request.auth.uid;
    }

    // ---- MATCH RULES ----

    // 0. User Metadata
    match /users/{userId} {
      allow read: if isMasterAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if isMasterAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // 1. Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId) || (request.auth != null && resource.data.contact_email == request.auth.token.email);
      allow update: if isMasterAdmin() || (isOrgMember(orgId) && hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']));
      allow create: if isAuthenticated(); 

      // 2. Staff: Scoped by OrgId
      match /staff/{staffId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (request.auth.uid == staffId || hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']));
      }

      // 3. Facilities
      match /facilities/{facilityId} {
        allow read: if isOrgMember(orgId) && hasFacilityAccess(orgId, facilityId);
        allow write: if isOrgMember(orgId) && (
          isMasterAdmin() || 
          hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']) || 
          isOrgPrimaryContact(orgId)
        );

        match /rooms/{roomId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId) && (
            hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId)
          );
        }

        match /beds/{bedId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId) && (
            hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId)
          );
        }
      }

      // 4. Patients: Deeply Scoped
      match /patients/{patientId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (
                       (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) && hasFacilityAccess(orgId, request.resource.data.facility_id)) ||
                       isOrgPrimaryContact(orgId)
                     );

        // 5. Clinical Data (Sub-collections)
        match /vital_signs/{vitalId} {
          allow read: if isOrgMember(orgId);
          allow create: if isOrgMember(orgId) && (hasOrgRole(orgId, ['nurse', 'physician']) || isOrgPrimaryContact(orgId)) && isValidVital(request.resource.data);
          allow update, delete: if false; // IMMUTABLE CLINICAL RECORDS
        }

        // Catch-all for other clinical sub-collections
        match /{clinicalData=**} {
           allow read: if isOrgMember(orgId);
           allow write: if isOrgMember(orgId) && (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId));
        }
      }

      // 6. Audit Logs: Global Append-Only
      match /audit_logs/{logId} {
        allow read: if isMasterAdmin() || (isOrgMember(orgId) && hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']));
        allow create: if isOrgMember(orgId);
        allow update, delete: if false; 
      }

      match /audit_log/{logId} {
        allow read: if isMasterAdmin() || (isOrgMember(orgId) && hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']));
        allow create: if isOrgMember(orgId);
        allow update, delete: if false; 
      }

      // 7. Handover Notes & Acknowledgemts
      match /handover_notes/{noteId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId));

        match /acks/{ackId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
      }

      // 8. Incidents (falls monitoring)
      match /incidents/{incidentId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'nurse', 'physician', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId));
      }

      // 9. Invitations
      match /invitations/{invitationId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId));
      }

      // 10. Intelligence Summaries
      match /intelligence_summaries/{summaryId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId) && (hasOrgRole(orgId, ['admin', 'CLIENT_ADMIN', 'FACILITY_ADMIN']) || isOrgPrimaryContact(orgId));
      }
    }

    // Global Audit Logs (Outside Org scope for system-wide auditing)
    match /audit_logs/{logId} {
      allow read: if isMasterAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // 7. Demo Leads: Public Append-Only Lead Capture
    match /demo_leads/{leadId} {
      allow create: if true; 
      allow read, update, delete: if isMasterAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
